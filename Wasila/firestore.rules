rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to search/read services, but only authenticated users can write
    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow anyone to read/write bookings (used by backend/agents and frontend)
    match /bookings/{document=**} {
      allow read, write: if true;
    }

    // Default rule for all other collections
    match /{document=**} {
      // Sirf authenticated users ko read/write allow karein
      allow read, write: if request.auth != null;
    }
  }
}
